# Get this from `npx convex dev` or your Convex dashboard
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Shared Vercel AI Gateway setup for photo tagging
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=moonshotai/kimi-k2.5

# Google Places API key (enable billing plus Places API and Geocoding API)
GOOGLE_PLACES_API_KEY=your_api_key_here
